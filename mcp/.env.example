# Supabase project (same project your Onot app uses)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Personal access token generated from the Onot web app:
#   workspace context menu → "AI agents" → New token
# The token is shown once at creation; treat it like a password.
ONOT_TOKEN=onot_replace-me

# Base URL of your Onot deployment. Used to call /api/mcp/exchange.
# For local dev: http://localhost:3000
ONOT_API_URL=https://onot.app
